0026\", \"uniqueId\": \"177708986977800026\", \"activeTab\": \"HEADER\", \"responseActiveTab\": \"BODY\", \"protocol\": \"HTTP\", \"method\": \"POST\", \"name\": \"psp-start\", \"unSaved\": true, \"customizeRequest\": false, \"customizeRequestEnvEnable\": true, \"children\": [{\"polymorphicName\": \"MsCommonElement\", \"assertionConfig\": {\"enableGlobal\": false, \"assertions\": [{\"assertionType\": \"RESPONSE_BODY\", \"enable\": true, \"name\": \"assert webhook data={}\", \"id\": \"1777099177350\", \"projectId\": null, \"assertionBodyType\": \"JSON_PATH\", \"jsonPathAssertion\": {\"assertions\": [{\"id\": \"1777099177349\", \"enable\": true, \"expression\": \"$.data\", \"condition\": \"EQUALS\", \"expectedValue\": \"{}\", \"valid\": true}]}, \"xpathAssertion\": {\"responseFormat\": \"XML\", \"assertions\": []}, \"documentAssertion\": null, \"regexAssertion\": {\"assertions\": []}, \"bodyAssertionClassByType\": \"io.metersphere.project.api.assertion.body.MsJSONPathAssertion\", \"bodyAssertionDataByType\": {\"assertions\": [{\"id\": \"1777099177349\", \"enable\": true, \"expression\": \"$.data\", \"condition\": \"EQUALS\", \"expectedValue\": \"{}\", \"valid\": true}]}}]}, \"postProcessorConfig\": {\"enableGlobal\": false, \"processors\": [{\"processorType\": \"SCRIPT\", \"name\": \"debug-response-step26\", \"enable\": true, \"projectId\": null, \"stepId\": null, \"script\": \"# scenario_1 debug response log\\ncode = str(prev.getResponseCode())\\nbody = prev.getResponseDataAsString()\\nlog.info(\\\"[scenario_1][step 26][psp-start] responseCode=\\\" + code)\\nlog.info(\\\"[scenario_1][step 26][psp-start] responseBody=\\\" + str(body)[:2000])\\nif code != \\\"200\\\":\\n    raise Exception(\\\"scenario_1 step 26 HTTP status not 200: \\\" + code + \\\", body=\\\" + str(body)[:500])\\n\", \"scriptLanguage\": \"PYTHON\", \"enableCommonScript\": false, \"commonScriptInfo\": {\"id\": \"\", \"deleted\": false, \"name\": \"\", \"script\": \"\", \"scriptLanguage\": \"BEANSHELL