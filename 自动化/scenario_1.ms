notifications\", \"query\": [], \"rest\": [], \"url\": \"/dpu-openapi/webhook-notifications\", \"polymorphicName\": \"MsHTTPElement\", \"resourceId\": null, \"stepId\": \"177693258294200028\", \"uniqueId\": \"177693258294200028\", \"activeTab\": \"HEADER\", \"responseActiveTab\": \"BODY\", \"protocol\": \"HTTP\", \"method\": \"POST\", \"name\": \"esign\", \"unSaved\": true, \"customizeRequest\": false, \"customizeRequestEnvEnable\": true, \"children\": [{\"polymorphicName\": \"MsCommonElement\", \"assertionConfig\": {\"enableGlobal\": false, \"assertions\": [{\"assertionType\": \"RESPONSE_BODY\", \"enable\": true, \"name\": \"assert webhook data={}\", \"id\": \"1777099177358\", \"projectId\": null, \"assertionBodyType\": \"JSON_PATH\", \"jsonPathAssertion\": {\"assertions\": [{\"id\": \"1777099177357\", \"enable\": true, \"expression\": \"$.data\", \"condition\": \"EQUALS\", \"expectedValue\": \"{}\", \"valid\": true}]}, \"xpathAssertion\": {\"responseFormat\": \"XML\", \"assertions\": []}, \"documentAssertion\": null, \"regexAssertion\": {\"assertions\": []}, \"bodyAssertionClassByType\": \"io.metersphere.project.api.assertion.body.MsJSONPathAssertion\", \"bodyAssertionDataByType\": {\"assertions\": [{\"id\": \"1777099177357\", \"enable\": true, \"expression\": \"$.data\", \"condition\": \"EQUALS\", \"expectedValue\": \"{}\", \"valid\": true}]}}]}, \"postProcessorConfig\": {\"enableGlobal\": false, \"processors\": [{\"processorType\": \"SCRIPT\", \"name\": \"debug-response-step28\", \"enable\": true, \"projectId\": null, \"stepId\": null, \"script\": \"# scenario_1 debug response log\\ncode = str(prev.getResponseCode())\\nbody = prev.getResponseDataAsString()\\nlog.info(\\\"[scenario_1][step 28][esign] responseCode=\\\" + code)\\nlog.info(\\\"[scenario_1][step 28][esign] responseBody=\\\" + str(body)[:2000])\\nif code != \\\"200\\\":\\n    raise Exception(\\\"scenario_1 step 28 HTTP status not 200: \\\" + code + \\\", body=\\\" + str(body)[:500])\\n\", \"scriptLanguage\": \"PYTHON\", \"enableCommonScript\": false, \"commonScriptInfo\": {\"id\": \"\", \"deleted\": false, \"name\": \"\", \"script\": \"\", \"scriptLanguage\": \"BEANSHELL_JSR233\", \"params\": []}, \"valid\": true, \"id\": \"1777099177360\"}, {\"processorType\": \"SQL\", \"name\": \"SQL final dpu_credit_offer\", \"enable\": true, \"projectId\": null, \"stepId\": null, \"script\": \"SELECT lender_approved_offer_id, status, approved_limit_amount, approved_limit_currency, signed_limit_amount, signed_limit_currency, e_sign_status\\nFROM dpu_seller_center.dpu_credit_offer\\nWHERE merchant_id = '${merchantId}'\\nORDER BY created_at DESC\\nLIMIT 1;\", \"queryTimeout\": 10000, \"resultVariable\": \"finalCreditOfferRow\", \"variableNames\": \"\", \"dataSourceId\": \"177683680147900000\", \"dataSourceName\": \"reg\", \"extractParams\": [], \"id\": \"177711900000000010\"}, {\"processorType\": \"SQL\", \"name\": \"SQL final lender_event_count\", \"enable\": true, \"projectId\": null, \"stepId\": null, \"script\": \"SELECT COUNT(*) AS event_count\\nFROM dpu_seller_center.dpu_lender_event\\nWHERE merchant_id = '${merchantId}'\\n  AND event_type IN ('underwrittenLimit.completed', 'approvedoffer.completed', 'psp.verification.started', 'psp.verification.completed', 'esign.completed');\", \"queryTimeout\": 10000, \"resultVariable\": \"finalWebhookEventCount\", \"variableNames\": \"\", \"dataSourceId\": \"177683680147900000\", \"dataSourceName\": \"reg\", \"extractParams\": [], \"id\": \"177711900000000011\"}, {\"processorType\": \"SCRIPT\", \"name\": \"assert-final-db-state\", \"enable\": true, \"projectId\": null, \"stepId\": null, \"script\": \"import re\\n\\ndef text_value(value):\\n    if value is None:\\n        return \\\"\\\"\\n    return str(value).strip()\\n\\ndef first_int(value):\\n    match = re.search(r'(-?\\\\d+)', text_value(value))\\n    if match:\\n        return int(match.group(1))\\n    return 0\\n\\nrow = text_value(vars.get(\\\"finalCreditOfferRow\\\"))\\nevent_count_raw = text_value(vars.get(\\\"finalWebhookEventCount\\\"))\\nlender_approved_offer_id = text_value(vars.get(\\\"lenderApprovedOfferId\\\"))\\nexpected_amount = text_value(vars.get(\\\"signedAmount\\\") or vars.get(\\\"approvedAmount\\\") or \\\"500000\\\")\\n\\nif row in (\\\"\\\", \\\"None\\\", \\\"[]\\\"):\\n    raise Exception(\\\"Final dpu_credit_offer SQL returned empty result for merchantId=\\\" + text_value(vars.get(\\\"merchantId\\\")))\\nif lender_approved_offer_id == \\\"\\\":\\n    raise Exception(\\\"lenderApprovedOfferId is empty before final DB assertion\\\")\\nif lender_approved_offer_id not in row:\\n    raise Exception(\\\"Final dpu_credit_offer row does not contain lenderApprovedOfferId=\\\" + lender_approved_offer_id + \\\"; row=\\\" + row)\\nif expected_amount != \\\"\\\" and expected_amount not in row:\\n    raise Exception(\\\"Final dpu_credit_offer row does not contain expected amount=\\\" + expected_amount + \\\"; row=\\\" + row)\\nif \\\"SUCCESS\\\" not in row:\\n    raise Exception(\\\"Final dpu_credit_offer row does not show e_sign_status SUCCESS; row=\\\" + row)\\n\\nevent_count = first_int(event_count_raw)\\nif event_count < 4:\\n    raise Exception(\\\"Expected at least 4 lender events after eSign, got \\\" + str(event_count) + \\\"; raw=\\\" + event_count_raw)\\n\\nvars.put(\\\"finalCreditOfferRow\\\", row)\\nvars.put(\\\"finalWebhookEventCount\\\", str(event_count))\\nlog.info(\\\"[scenario_1][final-db] finalCreditOfferRow=\\\" + row)\\nlog.info(\\\"[scenario_1][final-db] finalWebhookEventCount=\\\" + str(event_count))\", \"scriptLanguage\": \"PYTHON\", \"enableCommonScript\": false, \"commonScriptInfo\": {\"id\": \"\", \"deleted\": false, \"name\": \"\", \"script\": \"\", \"scriptLanguage\": \"BEANSHELL_JSR233\", \"params\": []}, \"valid\": true, \"id\": \"177711900000000012\"}]}, \"preProcessorConfig\": {\"enableGlobal\": false, \"processors\": [{\"processorType\": \"SQL\", \"name\": \"\", \"enable\": true, \"projectId\": null, \"stepId\": null, \"script\": \"SELECT lender_approved_offer_id\\nFROM dpu_seller_center.dpu_credit_offer\\nWHERE merchant_id = '${merchantId}'\\nORDER BY created_at DESC\\nLIMIT 1;\", \"queryTimeout\": 0, \"resultVariable\": \"lenderApprovedOfferId\", \"variableNames\": \"\", \"dataSourceId\": \"177683680147900000\", \"dataSourceName\": \"reg\", \"extractParams\": []}, {\"processorType\": \"SCRIPT\", \"name\": \"脚本名称\", \"enable\": true, \"projectId\": null, \"stepId\": null, \"script\": \"import re\\nimport uuid\\nfrom datetime import datetime, timezone\\n\\ndef extract_value(raw):\\n    s = str(raw).strip()\\n    if s == \\\"\\\" or s == \\\"None\\\" or s == \\\"[]\\\":\\n        return \\\"\\\"\\n    m = re.search(r'=\\\\s*([^}\\\\]]+)', s)\\n    if m:\\n        return m.group(1).strip()\\n    return s\\n\\nlender_approved_offer_id = extract_value(vars.get(\\\"lenderApprovedOfferId\\\"))\\npreferred_currency = str(vars.get(\\\"preferredCurrency\\\") or \\\"USD\\\")\\n\\nif lender_approved_offer_id == \\\"\\\":\\n    raise Exception(\\\"Missing lenderApprovedOfferId before eSign webhook; check approved-offer SQL/result first\\\")\\n\\nsigned_amount = vars.get(\\\"signedAmount\\\")\\nif signed_amount is None or str(signed_amount) == \\\"\\\":\\n    signed_amount = \\\"500000\\\"\\n\\nevent_id = str(uuid.uuid4())\\ndatetime_utc = datetime.now(timezone.utc).strftime(\\\"%Y-%m-%dT%H:%M:%SZ\\\")\\nlast_updated_on = datetime.now().strftime(\\\"%Y-%m-%d %H:%M:%S\\\")\\n\\nvars.put(\\\"lenderApprovedOfferId\\\", lender_approved_offer_id)\\nvars.put(\\\"signedAmount\\\", str(signed_amount))\\nvars.put(\\\"eventId\\\", event_id)\\nvars.put(\\\"datetime_utc\\\", datetime_utc)\\nvars.put(\\\"lastUpdatedOn\\\", last_updated_on)\\n\\nlog.info(\\\"merchantId=\\\" + str(vars.get(\\\"merchantId\\\")))\\nlog.info(\\\"preferredCurrency=\\\" + preferred_currency)\\nlog.info(\\\"lenderApprovedOfferId=\\\" + lender_approved_offer_id)\\nlog.info(\\\"signedAmount=\\\" + str(signed_amount))\", \"scriptLanguage\": \"PYTHON\", \"enableCommonScript\": false, \"commonScriptInfo\": {\"id\": \"\", \"deleted\": false, \"name\": \"\", \"script\": \"\", \"scriptLanguage\": \"BEANSHELL_JSR233\", \"params\": []}, \"valid\": true}, {\"processorType\": \"SCRIPT\", \"name\": \"debug-webhook-vars-step28\", \"enable\": true, \"projectId\": null, \"stepId\": null, \"script\": \"# scenario_1 webhook request variable log\\nlog.info(\\\"[scenario_1][webhook step 28] eventType=esign.completed\\\")\\nlog.info(\\\"[scenario_1][webhook step 28] phone=\\\" + str(vars.get(\\\"phone\\\")))\\nlog.info(\\\"[scenario_1][webhook step 28] merchantId=\\\" + str(vars.get(\\\"merchantId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 28] preferredCurrency=\\\" + str(vars.get(\\\"preferredCurrency\\\")))\\nlog.info(\\\"[scenario_1][webhook step 28] eventId=\\\" + str(vars.get(\\\"eventId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 28] dpuMerchantAccountId=\\\" + str(vars.get(\\\"dpuMerchantAccountId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 28] dpuLimitApplicationId=\\\" + str(vars.get(\\\"dpuLimitApplicationId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 28] dpuApplicationId=\\\" + str(vars.get(\\\"dpuApplicationId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 28] lenderApprovedOfferId=\\\" + str(vars.get(\\\"lenderApprovedOfferId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 28] underwrittenOriginalRequestId=\\\" + str(vars.get(\\\"underwrittenOriginalRequestId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 28] approvedOriginalRequestId=\\\" + str(vars.get(\\\"approvedOriginalRequestId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 28] underwrittenAmount=\\\" + str(vars.get(\\\"underwrittenAmount\\\")))\\nlog.info(\\\"[scenario_1][webhook step 28] approvedAmount=\\\" + str(vars.get(\\\"approvedAmount\\\")))\\nlog.info(\\\"[scenario_1][webhook step 28] signedAmount=\\\" + str(vars.get(\\\"signedAmount\\\")))\\n\", \"scriptLanguage\": \"PYTHON\", \"enableCommon