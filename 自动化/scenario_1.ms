(raw).strip()\\n    if s == \\\"[]\\\" or s == \\\"\\\" or s == \\\"None\\\":\\n        return \\\"\\\"\\n    m = re.search(r'=\\\\s*([^}\\\\]]+)', s)\\n    if m:\\n        return m.group(1).strip()\\n    return s\\n\\nmerchant_id_raw = vars.get(\\\"merchantId\\\")\\npreferred_currency_raw = vars.get(\\\"preferredCurrency\\\")\\n\\nmerchant_id = extract_value(merchant_id_raw)\\npreferred_currency = extract_value(preferred_currency_raw) or \\\"USD\\\"\\n\\nvars.put(\\\"merchantId\\\", merchant_id)\\nvars.put(\\\"preferredCurrency\\\", preferred_currency)\\n\\nlog.info(\\\"merchantId(raw)=\\\" + str(merchant_id_raw))\\nlog.info(\\\"merchantId(clean)=\\\" + merchant_id)\\nlog.info(\\\"preferredCurrency(raw)=\\\" + str(preferred_currency_raw))\\nlog.info(\\\"preferredCurrency(clean)=\\\" + preferred_currency)\",\"scriptLanguage\":\"PYTHON\",\"enableCommonScript\":false,\"commonScriptInfo\":{\"id\":\"\",\"deleted\":false,\"name\":\"\",\"script\":\"\",\"scriptLanguage\":\"BEANSHELL_JSR233\",\"params\":[]},\"valid\":true},{\"processorType\":\"SQL\",\"name\":\"前置 SQL 查询\",\"enable\":true,\"projectId\":null,\"stepId\":null,\"script\":\"SELECT limit_application_unique_id\\nFROM dpu_seller_center.dpu_limit_application\\nWHERE merchant_id = '${merchantId}'\\nORDER BY created_at DESC\\nLIMIT 1;\",\"queryTimeout\":10000,\"resultVariable\":\"dpuLimitApplicationId\",\"variableNames\":\"\",\"dataSourceId\":\"177683680147900000\",\"dataSourceName\":\"reg\",\"extractParams\":[]},{\"processorType\":\"SQL\",\"name\":\"前置 SQL 查询\",\"enable\":true,\"projectId\":null,\"stepId\":null,\"script\":\"SELECT authorization_id\\nFROM dpu_seller_center.dpu_auth_token\\nWHERE merchant_id = '${merchantId}'\\n  AND authorization_party = 'SP'\\n  AND status = 'ACTIVE'\\n  AND authorization_id IS NOT NULL\\nORDER BY created_at DESC\\nLIMIT 1;\",\"queryTimeout\":10000,\"resultVariable\":\"dpuMerchantAccountId\",\"variableNames\":\"\",\"dataSourceId\":\"177683680147900000\",\"dataSourceName\":\"reg\",\"ex