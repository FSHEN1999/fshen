get(\\\"merchantId\\\")))\\nlog.info(\\\"dpuMerchantAccountId=\\\" + merchant_account_id)\\nlog.info(\\\"lenderApprovedOfferId=\\\" + lender_approved_offer_id)\", \"scriptLanguage\": \"PYTHON\", \"enableCommonScript\": false, \"commonScriptInfo\": {\"id\": \"\", \"deleted\": false, \"name\": \"\", \"script\": \"\", \"scriptLanguage\": \"BEANSHELL_JSR233\", \"params\": []}, \"valid\": true, \"id\": 1777091180483}, {\"processorType\": \"SCRIPT\", \"name\": \"debug-webhook-vars-step27\", \"enable\": true, \"projectId\": null, \"stepId\": null, \"script\": \"# scenario_1 webhook request variable log\\nlog.info(\\\"[scenario_1][webhook step 27] eventType=psp.verification.completed\\\")\\nlog.info(\\\"[scenario_1][webhook step 27] phone=\\\" + str(vars.get(\\\"phone\\\")))\\nlog.info(\\\"[scenario_1][webhook step 27] merchantId=\\\" + str(vars.get(\\\"merchantId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 27] preferredCurrency=\\\" + str(vars.get(\\\"preferredCurrency\\\")))\\nlog.info(\\\"[scenario_1][webhook step 27] eventId=\\\" + str(vars.get(\\\"eventId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 27] dpuMerchantAccountId=\\\" + str(vars.get(\\\"dpuMerchantAccountId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 27] dpuLimitApplicationId=\\\" + str(vars.get(\\\"dpuLimitApplicationId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 27] dpuApplicationId=\\\" + str(vars.get(\\\"dpuApplicationId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 27] lenderApprovedOfferId=\\\" + str(vars.get(\\\"lenderApprovedOfferId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 27] underwrittenOriginalRequestId=\\\" + str(vars.get(\\\"underwrittenOriginalRequestId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 27] approvedOriginalRequestId=\\\" + str(vars.get(\\\"approvedOriginalRequestId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 27] underwrittenAmount=\\\" + str(vars.get(\\\"underwrittenAmount\\\")))\\nlog.info(\\\"[scenario_1][webhook step 27] approvedAmount=\\\" + str(vars.get(\\\"approvedAmount\\\")))\\nlog.info(\\\"[scenario_1][webhook step 27] signedAmount=\\\" + str(vars.get(\\\"signedAmount\\\")))\\n\", \"scriptLanguage\": \"PYTHON\", \"enableCommonScript\": false, \"commonScriptInfo\": {\"id\": \"\", \"deleted\": false, \"name\": \"\", \"script\": \"\", \"scriptLanguage\": \"BEANSHELL_JSR233\", \"params\": []}, \"valid\": true, \"id\": \"1777099177355\"}], \"activeItemId\": 1777091180483}}], \"executeLoading\": false, \"uploadFileIds\": [], \"linkFileIds\": [], \"deleteFileIds\": [], \"unLinkFileIds\": [], \"isNew\": false}",
