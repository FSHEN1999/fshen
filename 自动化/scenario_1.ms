ntId\\\")))\\nlog.info(\\\"dpuMerchantAccountId=\\\" + merchant_account_id)\\nlog.info(\\\"lenderApprovedOfferId=\\\" + lender_approved_offer_id)\", \"scriptLanguage\": \"PYTHON\", \"enableCommonScript\": false, \"commonScriptInfo\": {\"id\": \"\", \"deleted\": false, \"name\": \"\", \"script\": \"\", \"scriptLanguage\": \"BEANSHELL_JSR233\", \"params\": []}, \"valid\": true, \"id\": 1777091152864}, {\"processorType\": \"SCRIPT\", \"name\": \"debug-webhook-vars-step26\", \"enable\": true, \"projectId\": null, \"stepId\": null, \"script\": \"# scenario_1 webhook request variable log\\nlog.info(\\\"[scenario_1][webhook step 26] eventType=psp.verification.started\\\")\\nlog.info(\\\"[scenario_1][webhook step 26] phone=\\\" + str(vars.get(\\\"phone\\\")))\\nlog.info(\\\"[scenario_1][webhook step 26] merchantId=\\\" + str(vars.get(\\\"merchantId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 26] preferredCurrency=\\\" + str(vars.get(\\\"preferredCurrency\\\")))\\nlog.info(\\\"[scenario_1][webhook step 26] eventId=\\\" + str(vars.get(\\\"eventId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 26] dpuMerchantAccountId=\\\" + str(vars.get(\\\"dpuMerchantAccountId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 26] dpuLimitApplicationId=\\\" + str(vars.get(\\\"dpuLimitApplicationId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 26] dpuApplicationId=\\\" + str(vars.get(\\\"dpuApplicationId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 26] lenderApprovedOfferId=\\\" + str(vars.get(\\\"lenderApprovedOfferId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 26] underwrittenOriginalRequestId=\\\" + str(vars.get(\\\"underwrittenOriginalRequestId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 26] approvedOriginalRequestId=\\\" + str(vars.get(\\\"approvedOriginalRequestId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 26] underwrittenAmount=\\\" + str(vars.get(\\\"underwrittenAmount\\\")))\\nlog.info(\\\"[scenario_1][webhook step 26] approvedAmount=\\\" + str(vars.get(\\\"approvedAmount\\\")))\\nlog.info(\\\"[scenario_1][webhook step 26] signedAmount=\\\" + str(vars.get(\\\"signedAmount\\\")))\\n\", \"scriptLanguage\": \"PYTHON\", \"enableCommonScript\": false, \"commonScriptInfo\": {\"id\": \"\", \"deleted\": false, \"name\": \"\", \"script\": \"\", \"scriptLanguage\": \"BEANSHELL_JSR233\", \"params\": []}, \"valid\": true, \"id\": \"1777099177351\"}], \"activeItemId\": 1777091152864}}], \"executeLoading\": false, \"uploadFileIds\": [], \"linkFileIds\": [], \"deleteFileIds\": [], \"unLinkFileIds\": [], \"isNew\": false}",
