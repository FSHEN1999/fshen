ncy == \\\"CNY\\\" else \\\"Float\\\"\\n\\nvars.put(\\\"eventId\\\", event_id)\\nvars.put(\\\"underwrittenOriginalRequestId\\\", \\\"req_\\\" + event_id.replace(\\\"-\\\", \\\"\\\"))\\nvars.put(\\\"datetime_utc\\\", datetime_utc)\\nvars.put(\\\"lastUpdatedOn\\\", last_updated_on)\\nvars.put(\\\"chargeBases\\\", charge_bases)\\n\\nsuffix = str(vars.get(\\\"dpuLimitApplicationId\\\") or event_id.replace(\\\"-\\\", \\\"\\\"))\\nvars.put(\\\"lenderCreditId\\\", \\\"lcredit_\\\" + suffix)\\nvars.put(\\\"lenderLoanId\\\", \\\"lloan_\\\" + suffix)\\nvars.put(\\\"lenderRepaymentScheduled\\\", \\\"lrs_\\\" + suffix)\\nvars.put(\\\"lenderRepaymentId\\\", \\\"lrepay_\\\" + suffix)\\n\\nif vars.get(\\\"underwrittenAmount\\\") is None or str(vars.get(\\\"underwrittenAmount\\\")) == \\\"\\\":\\n    vars.put(\\\"underwrittenAmount\\\", \\\"500000\\\")\",\"scriptLanguage\":\"PYTHON\",\"enableCommonScript\":false,\"commonScriptInfo\":{\"id\":\"\",\"deleted\":false,\"name\":\"\",\"script\":\"\",\"scriptLanguage\":\"BEANSHELL_JSR233\",\"params\":[]},\"valid\":true},{\"processorType\":\"SCRIPT\",\"name\":\"debug-webhook-vars-step24\",\"enable\":true,\"projectId\":null,\"stepId\":null,\"script\":\"# scenario_1 webhook request variable log\\nlog.info(\\\"[scenario_1][webhook step 24] eventType=underwrittenLimit.completed\\\")\\nlog.info(\\\"[scenario_1][webhook step 24] phone=\\\" + str(vars.get(\\\"phone\\\")))\\nlog.info(\\\"[scenario_1][webhook step 24] merchantId=\\\" + str(vars.get(\\\"merchantId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 24] preferredCurrency=\\\" + str(vars.get(\\\"preferredCurrency\\\")))\\nlog.info(\\\"[scenario_1][webhook step 24] eventId=\\\" + str(vars.get(\\\"eventId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 24] dpuMerchantAccountId=\\\" + str(vars.get(\\\"dpuMerchantAccountId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 24] dpuLimitApplicationId=\\\" + str(vars.get(\\\"dpuLimitApplicationId\\\")))\\nlog.info(\\\"[scenario_1][webhook step 24] d