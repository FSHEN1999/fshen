essorType\":\"SCRIPT\",\"name\":\"debug-response-step1\",\"enable\":true,\"projectId\":null,\"stepId\":null,\"script\":\"# scenario_1 debug response log\\ncode = str(prev.getResponseCode())\\nbody = prev.getResponseDataAsString()\\nlog.info(\\\"[scenario_1][step 1][发送注册短信] responseCode=\\\" + code)\\nlog.info(\\\"[scenario_1][step 1][发送注册短信] responseBody=\\\" + str(body)[:2000])\\nif code != \\\"200\\\":\\n    raise Exception(\\\"scenario_1 step 1 HTTP status not 200: \\\" + code + \\\", body=\\\" + str(body)[:500])\\n\",\"scriptLanguage\":\"PYTHON\",\"enableCommonScript\":false,\"commonScriptInfo\":{\"id\":\"\",\"deleted\":false,\"name\":\"\",\"script\":\"\",\"scriptLanguage\":\"BEANSHELL_JSR233\",\"params\":[]},\"valid\":true,\"id\":\"1777099177300\"}]},\"preProcessorConfig\":{\"enableGlobal\":false,\"processors\":[{\"processorType\":\"SCRIPT\",\"name\":\"脚本名称\",\"enable\":true,\"projectId\":null,\"stepId\":null,\"script\":\"import random\\n\\n# 手机号号段\\nprefixes = [\\n    \\\"130\\\",\\\"131\\\",\\\"132\\\",\\\"133\\\",\\\"135\\\",\\\"136\\\",\\\"137\\\",\\\"138\\\",\\\"139\\\",\\n    \\\"150\\\",\\\"151\\\",\\\"152\\\",\\\"155\\\",\\\"156\\\",\\\"157\\\",\\\"158\\\",\\\"159\\\",\\n    \\\"166\\\",\\\"171\\\",\\\"172\\\",\\\"173\\\",\\\"175\\\",\\\"176\\\",\\\"177\\\",\\\"178\\\",\\n    \\\"180\\\",\\\"181\\\",\\\"182\\\",\\\"183\\\",\\\"184\\\",\\\"185\\\",\\\"186\\\",\\\"187\\\",\\\"188\\\",\\\"189\\\",\\n    \\\"191\\\",\\\"193\\\",\\\"195\\\",\\\"196\\\",\\\"198\\\",\\\"199\\\"\\n]\\n\\n# 生成手机号\\nprefix = random.choice(prefixes)\\nsuffix = str(random.randint(0, 99999999)).zfill(8)\\nphone_number = prefix + suffix\\n\\n# 关键：生成一次，永久存入变量，后续所有请求都用这个\\nvars.put(\\\"phoneNumber\\\", phone_number)\\nvars.put(\\\"phone\\\", phone_number)  # 直接给后续请求用的变量\\n\\nlog.info(\\\"===== 生成固定手机号: \\\" + phone_number + \\\" =====\\\")\",\"scriptLanguage\":\"PYTHON\",\"enableCommonScript\":false,\"commonScriptInfo\":{\"id\":\"\",\"deleted\":false,\"name\":\"\",\"script\":\"\",\"scr