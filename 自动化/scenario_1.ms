ferredCurrency\\\") or \\\"USD\\\")\\n\\nif dpu_application_id == \\\"\\\":\\n    raise Exception(\\\"缺少 dpuApplicationId\\\")\\n\\napproved_amount = vars.get(\\\"approvedAmount\\\")\\nif approved_amount is None or str(approved_amount) == \\\"\\\":\\n    approved_amount = \\\"500000\\\"\\n\\nevent_id = str(uuid.uuid4())\\ndatetime_utc = datetime.now(timezone.utc).strftime(\\\"%Y-%m-%dT%H:%M:%SZ\\\")\\noffer_start_date = datetime.now().strftime(\\\"%Y-%m-%d\\\")\\noffer_end_date = (datetime.now() + timedelta(days=90)).strftime(\\\"%Y-%m-%d\\\")\\ncharge_bases = \\\"Fixed\\\" if preferred_currency == \\\"CNY\\\" else \\\"Float\\\"\\nlender_approved_offer_id = \\\"lender-\\\" + dpu_application_id\\n\\nvars.put(\\\"dpuApplicationId\\\", dpu_application_id)\\nvars.put(\\\"approvedAmount\\\", str(approved_amount))\\nvars.put(\\\"eventId\\\", event_id)\\nvars.put(\\\"approvedOriginalRequestId\\\", \\\"req_\\\" + event_id.replace(\\\"-\\\", \\\"\\\"))\\nvars.put(\\\"datetime_utc\\\", datetime_utc)\\nvars.put(\\\"offerStartDate\\\", offer_start_date)\\nvars.put(\\\"offerEndDate\\\", offer_end_date)\\nvars.put(\\\"chargeBases\\\", charge_bases)\\nvars.put(\\\"lenderApprovedOfferId\\\", lender_approved_offer_id)\\n\\nlog.info(\\\"merchantId=\\\" + str(vars.get(\\\"merchantId\\\")))\\nlog.info(\\\"preferredCurrency=\\\" + preferred_currency)\\nlog.info(\\\"dpuApplicationId=\\\" + dpu_application_id)\\nlog.info(\\\"approvedAmount=\\\" + str(approved_amount))\\nlog.info(\\\"lenderApprovedOfferId=\\\" + lender_approved_offer_id)\",\"scriptLanguage\":\"PYTHON\",\"enableCommonScript\":false,\"commonScriptInfo\":{\"id\":\"\",\"deleted\":false,\"name\":\"\",\"script\":\"\",\"scriptLanguage\":\"BEANSHELL_JSR233\",\"params\":[]},\"valid\":true},{\"processorType\":\"SCRIPT\",\"name\":\"debug-webhook-vars-step25\",\"enable\":true,\"projectId\":null,\"stepId\":null,\"script\":\"# scenario_1 webhook request variable log\\nlog.info(\\\"[scenario_1][webhook step 25] eventType=approvedoffer.co