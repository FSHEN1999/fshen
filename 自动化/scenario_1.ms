\\\", dpu_limit_application_id)\\r\\n\\r\\nlog.info(\\\"dpuMerchantAccountId(raw)=\\\" + str(dpu_merchant_account_id_raw))\\r\\nlog.info(\\\"dpuMerchantAccountId(clean)=\\\" + dpu_merchant_account_id)\\r\\nlog.info(\\\"dpuLimitApplicationId(raw)=\\\" + str(dpu_limit_application_id_raw))\\r\\nlog.info(\\\"dpuLimitApplicationId(clean)=\\\" + dpu_limit_application_id)\",\"scriptLanguage\":\"PYTHON\",\"enableCommonScript\":false,\"commonScriptInfo\":{\"id\":\"\",\"deleted\":false,\"name\":\"\",\"script\":\"\",\"scriptLanguage\":\"BEANSHELL_JSR233\",\"params\":[]},\"valid\":true},{\"processorType\":\"SCRIPT\",\"name\":\"脚本名称\",\"enable\":true,\"projectId\":null,\"stepId\":null,\"script\":\"import uuid\\nfrom datetime import datetime, timezone\\n\\npreferred_currency = vars.get(\\\"preferredCurrency\\\")\\nif preferred_currency is None or preferred_currency == \\\"\\\":\\n    preferred_currency = \\\"USD\\\"\\n\\nevent_id = str(uuid.uuid4())\\ndatetime_utc = datetime.now(timezone.utc).strftime(\\\"%Y-%m-%dT%H:%M:%SZ\\\")\\nlast_updated_on = datetime.now().strftime(\\\"%Y-%m-%d %H:%M:%S\\\")\\ncharge_bases = \\\"Fixed\\\" if preferred_currency == \\\"CNY\\\" else \\\"Float\\\"\\n\\nvars.put(\\\"eventId\\\", event_id)\\nvars.put(\\\"underwrittenOriginalRequestId\\\", \\\"req_\\\" + event_id.replace(\\\"-\\\", \\\"\\\"))\\nvars.put(\\\"datetime_utc\\\", datetime_utc)\\nvars.put(\\\"lastUpdatedOn\\\", last_updated_on)\\nvars.put(\\\"chargeBases\\\", charge_bases)\\n\\nsuffix = str(vars.get(\\\"dpuLimitApplicationId\\\") or event_id.replace(\\\"-\\\", \\\"\\\"))\\nvars.put(\\\"lenderCreditId\\\", \\\"lcredit_\\\" + suffix)\\nvars.put(\\\"lenderLoanId\\\", \\\"lloan_\\\" + suffix)\\nvars.put(\\\"lenderRepaymentScheduled\\\", \\\"lrs_\\\" + suffix)\\nvars.put(\\\"lenderRepaymentId\\\", \\\"lrepay_\\\" + suffix)\\n\\nif vars.get(\\\"underwrittenAmount\\\") is None or str(vars.get(\\\"underwrittenAmount\\\")) == \\\"\\\":\\n    vars.put(\\\"underwrittenAmount\\\", \\\"500000\\\")\