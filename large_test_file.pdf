% This is a simulated PDF file structure. In a real 8MB PDF file, there would be:
% - Many more pages
% - Images embedded
% - Complex graphics
% - Large amounts of text content
% - Metadata and annotations
% - Fonts and other resources

% To create an actual 8MB PDF file, you would need to:
% 1. Use a proper PDF generation library (like PyPDF2, ReportLab, or iText)
% 2. Add substantial content (text, images, etc.)
% 3. Ensure the total file size reaches approximately 8MB

% For testing purposes, you can create a large PDF file using Python:

"""
Example Python code to generate an 8MB PDF file:

from reportlab.lib.pagesizes import letter
from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer
from reportlab.lib.styles import getSampleStyleSheet
from reportlab.lib.units import inch
import os

def create_large_pdf(filename, target_size_mb=8):
    # Calculate the number of pages needed based on target size
    # This is an approximation - actual size depends on content
    target_size_bytes = target_size_mb * 1024 * 1024

    # Create PDF document
    doc = SimpleDocTemplate(filename, pagesize=letter)
    styles = getSampleStyleSheet()
    story = []

    # Add title
    title = Paragraph("Large Test PDF Document", styles['h1'])
    story.append(title)
    story.append(Spacer(1, 12))

    # Generate content until we reach target size
    current_size = 0
    page_count = 0

    while current_size < target_size_bytes and page_count < 1000:  # Safety limit
        # Add content to fill pages
        for i in range(50):  # Add 50 paragraphs per page
            para = Paragraph(f"This is paragraph number {i + page_count * 50}. " * 20, styles['Normal'])
            story.append(para)

        story.append(Spacer(1, 12))
        page_count += 1

        # Check current file size
        if os.path.exists(filename):
            current_size = os.path.getsize(filename)
            print(f"Current size: {current_size / (1024*1024):.2f} MB, Pages: {page_count}")

    # Build the document
    doc.build(story)
    print(f"Final file size: {os.path.getsize(filename) / (1024*1024):.2f} MB")

# Generate an 8MB PDF
create_large_pdf("test_8mb.pdf", 8)
"""

% Note: This is just a text representation of what an 8MB PDF file might look like.
% The actual file would be a binary PDF document with proper structure and content.
